# OpenAI (server-side, used by api/* routes via config/openai.js)
OPENAI_API_KEY=

# Firebase (client-side; loaded by src/firebase.js)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Appwrite (client-side; loaded by src/appwrite.js + src/services/fileStorage.js)
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=
VITE_APPWRITE_BUCKET_ID=

# Optional: override API base for the frontend
# VITE_API_BASE=/api
